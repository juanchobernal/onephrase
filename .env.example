# Copy this file to `.env.local` and fill in your keys. Never commit `.env.local`.

# Deepgram API key for streaming STT. https://console.deepgram.com/
VITE_DEEPGRAM_API_KEY=

# Google Cloud API key with "Cloud Translation API" enabled.
# https://console.cloud.google.com/apis/library/translate.googleapis.com
VITE_GOOGLE_API_KEY=
